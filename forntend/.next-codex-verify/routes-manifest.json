{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/v1/:path*",
        "destination": "http://localhost:8000/api/v1/:path*",
        "regex": "^/api/v1(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog-detail/[id]",
      "regex": "^/blog\\-detail/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/blog\\-detail/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/blog-detail-02/[id]",
      "regex": "^/blog\\-detail\\-02/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/blog\\-detail\\-02/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product-detail/[id]",
      "regex": "^/product\\-detail/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/product\\-detail/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/shop-default-grid/product-type/[productType]",
      "regex": "^/shop\\-default\\-grid/product\\-type/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPproductType": "nxtPproductType"
      },
      "namedRegex": "^/shop\\-default\\-grid/product\\-type/(?<nxtPproductType>[^/]+?)(?:/)?$"
    },
    {
      "page": "/shop-default-grid/[category]",
      "regex": "^/shop\\-default\\-grid/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategory": "nxtPcategory"
      },
      "namedRegex": "^/shop\\-default\\-grid/(?<nxtPcategory>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/404",
      "regex": "^/404(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/404(?:/)?$"
    },
    {
      "page": "/about-us",
